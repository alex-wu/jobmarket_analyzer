# Copy to .env and fill in values. .env is gitignored.

# --- Source: Adzuna ---
# Free tier (verify current limits at https://developer.adzuna.com/)
# Required for the `adzuna` source adapter.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- LLM (optional) ---
# Pipeline materialises end-to-end with LLM_ENABLED=false. Enabling only
# fills gaps the deterministic path can't (e.g. ISCO-08 fuzzy match misses).
# Works with any OpenAI-compatible endpoint (OpenAI, Ollama, vLLM, LM Studio).
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# --- GitHub Release publishing (for refresh.yml; not needed locally) ---
# Provided automatically by GitHub Actions as ${{ secrets.GITHUB_TOKEN }}.
GH_TOKEN=
